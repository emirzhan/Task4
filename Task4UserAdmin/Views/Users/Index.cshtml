@model UsersIndexViewModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">User Management</h1>
        <p class="text-body-secondary mb-0">Toolbar actions apply to the selected rows only. There are no per-row action buttons.</p>
    </div>
    <div class="toolbar-filter">
        <label for="userFilter" class="form-label visually-hidden">Filter users</label>
        <input id="userFilter" type="search" class="form-control" placeholder="Filter" data-user-filter />
    </div>
</div>

<form asp-action="Bulk" method="post" data-user-admin-form>
    <div class="card shadow-sm">
        <div class="card-body border-bottom">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" name="action" value="Block" class="btn btn-primary" data-bulk-action-button title="Block selected users">
                        Block
                    </button>
                    <button type="submit" name="action" value="Unblock" class="btn btn-outline-secondary btn-icon" data-bulk-action-button title="Unblock selected users" aria-label="Unblock selected users">
                        <svg class="toolbar-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M11 6V4.75a3 3 0 0 0-6 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <path d="M11 6V4.75a3 3 0 0 1 3 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <rect x="3" y="6" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        </svg>
                    </button>
                    <button type="submit" name="action" value="Delete" class="btn btn-outline-danger btn-icon" data-bulk-action-button title="Delete selected users" aria-label="Delete selected users">
                        <svg class="toolbar-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M2.5 4.5h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <path d="M6 2.75h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <path d="M5 4.5v7.25a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1V4.5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                            <path d="M6.75 7v3.5M9.25 7v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </button>
                    <button type="submit" name="action" value="DeleteUnverified" class="btn btn-outline-danger btn-icon" data-bulk-action-button title="Delete selected unverified users" aria-label="Delete selected unverified users">
                        <svg class="toolbar-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="2.25" y="3.5" width="8.5" height="7" rx="1" stroke="currentColor" stroke-width="1.5" />
                            <path d="M2.75 4.5 6.5 7l3.75-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M11.75 4.75 14 7m0-2.25L11.75 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </button>
                </div>
                <div class="small text-body-secondary d-flex align-items-center">
                    Select rows with the leftmost checkbox, then use the toolbar.
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0 user-table">
                <thead>
                    <tr>
                        <th class="checkbox-column">
                            <input type="checkbox" class="form-check-input" data-select-all aria-label="Select all users" />
                        </th>
                        <th>Name</th>
                        <th>E-mail</th>
                        <th>Status</th>
                        <th>Last login</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="py-5 text-center text-body-secondary">No users found yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var user in Model.Users)
                    {
                        <tr data-user-row>
                            <td class="checkbox-column">
                                <input type="checkbox" class="form-check-input" name="selectedUserIds" value="@user.Id" data-select-row aria-label="Select @user.FullName" />
                            </td>
                            <td>
                                <div class="fw-semibold d-flex align-items-center gap-2">
                                    <span>@user.FullName</span>
                                    @if (user.IsCurrentUser)
                                    {
                                        <span class="badge rounded-pill text-bg-dark">You</span>
                                    }
                                </div>
                                <div class="small text-body-secondary">Registered @user.RegisteredAtText</div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge rounded-pill text-bg-@user.StatusCssClass">@user.StatusText</span>
                            </td>
                            <td>
                                <span data-bs-toggle="tooltip" title="@user.LastLoginTooltip">@user.LastLoginText</span>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</form>
