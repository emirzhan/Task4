@{
    var flash = Context.GetFlashMessage();
}

@if (flash is not null)
{
    <div class="alert alert-@flash.Level alert-dismissible fade show shadow-sm mb-4" role="alert">
        @flash.Text
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
